{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "npm"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "plugins.v2/p115strmhelper/requirements.txt"
      ],
      "matchPackageNames": [
        "full-strm-sync",
        "txt-tree-storage",
        "share-strm-scan"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "grpcio",
        "protobuf"
      ],
      "enabled": false
    },
    {
      "matchDepNames": [
        "node-version"
      ],
      "matchCurrentVersion": "20",
      "enabled": false
    }
  ]
}
